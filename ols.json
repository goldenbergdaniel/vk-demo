{
  "$schema": "https://raw.githubusercontent.com/DanielGavin/ols/master/misc/ols.schema.json",
  "collections": [
    {
      "name": "ext",
      "path": "ext"
    }
  ],
  "enable_document_symbols": true,
  "enable_document_links": false,
  "enable_semantic_tokens": true,
  "enable_format": false,
  "enable_hover": true,
  "enable_rename": true,
  "enable_snippets": true,
  "enable_reference": true,
  "enable_fake_methods": true,
  "enable_checker_only_saved": true,
  "verbose": true,
  "checker_args": "-vet-style -vet-cast",
  "profile": "vk_test",
  "profiles":
  [
    {
      "name": "main", 
      "checker_path": ["game"]
    },
    {
      "name": "vk_demo", 
      "checker_path": ["vk_demo"]
    },
    {
      "name": "other", 
      "checker_path": ["game/wav"]
    }
  ]
}
